# ─────────────────────────────────────────────────────────────
#  Finance Dashboard — Environment Variables
#
#  Steps:
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your Supabase credentials below
#  3. Run: npm install && npm run dev
#     → The app will set up your database automatically
#
#  Get credentials: supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL (e.g. https://abcxyz.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url

# Your Supabase anon/public key (starts with eyJ...)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Your Supabase service role key (starts with eyJ...)
# If provided, npm run dev will auto-create tables for you.
# Get it from: Project Settings → API → service_role key
# WARNING: Never expose this key in the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
